   "source": [
    "# finding studies that are about parkinson's disease and the gut microbiome\n",
    "# init \n",
    "mg = MGnipy()\n",
    "\n",
    "# search studies \n",
    "pd_studies = mg.studies.filter(search=\"parkinson's\")\n",
    "\n",
    "# previewing before getting all metadata\n",
    "pd_studies.explain()"
   ]
  },
